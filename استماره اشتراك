var userLat=null, userLng=null, userLocText='';

const DELIVERY_FEE={'12':120,'24':225};

function deliveryFee(){
  if(S.subType==='delivery'&&S.per) return DELIVERY_FEE[S.per]||0;
  return 0;
}

function calcPrice(){
  if(S.pkg&&S.per&&S.cnt){
    let t=PRICE[S.pkg][S.per][S.cnt];
    S.adds.forEach(function(a){if(ADDON_P[S.per][a])t+=ADDON_P[S.per][a];});
    t+=deliveryFee();
    document.getElementById('totalPr').textContent=t;
  }
}

function getTotal(){
  if(!S.pkg||!S.per||!S.cnt) return 0;
  let t=PRICE[S.pkg][S.per][S.cnt];
  S.adds.forEach(function(a){if(ADDON_P[S.per]&&ADDON_P[S.per][a])t+=ADDON_P[S.per][a];});
  t+=deliveryFee();
  return t;
}

function maxRep(){if(!S.pkg||!S.per||!S.cnt)return 0;return Math.ceil(parseInt(S.per)*S.cnt/PKG_N[S.pkg]);}

function refreshPlanner(){
  var pl=document.getElementById('plannerDiv');
  if(S.choice==='self'&&S.cnt>0&&S.per&&S.pkg){pl.classList.add('show');buildPlanner();}
  else pl.classList.remove('show');
}

function refreshBranchPlanner(){
  var bp=document.getElementById('branchPlannerDiv');
  if(S.choice==='branch'&&S.pkg&&S.per&&S.cnt){buildBranchPlanner();}
  else bp.classList.remove('show');
}

function buildBranchPlanner(){
  var bp=document.getElementById('branchPlannerDiv');
  var wrap=document.getElementById('branchDaysWrap');
  if(!S.pkg||!S.per||!S.cnt){bp.classList.remove('show');return;}
  var schedule=BRANCH_SCHEDULES[S.pkg][S.per][S.cnt];
  if(!schedule){bp.classList.remove('show');return;}
  bp.classList.add('show'); wrap.innerHTML='';
  for(var d=0;d<schedule.length;d++){
    var dayMeals=schedule[d];var mealsHtml='';
    for(var m=1;m<=S.cnt;m++){mealsHtml+='<div class="bp-meal-row"><div class="bp-meal-num">'+m+'</div><div class="bp-meal-name">'+(dayMeals[m]||'')+'</div></div>';}
    wrap.innerHTML+='<div class="bp-day-card"><div class="bp-dc-head">يوم '+(d+1)+'</div><div class="dc-body">'+mealsHtml+'</div></div>';
  }
}

function buildPlanner(){
  var days=parseInt(S.per);
  var meals=MEALS[S.pkg];
  var mr=maxRep();
  var total=days*S.cnt;
  var pname=S.pkg==='chi'?'الدجاج':'المنوع';
  document.getElementById('ruleNote').textContent='باقة '+pname+' | '+total+' وجبة ÷ '+PKG_N[S.pkg]+' أصناف = حد التكرار: '+mr+' مرة لكل صنف';
  var old=JSON.parse(JSON.stringify(S.plan));
  S.plan={};
  var wrap=document.getElementById('daysWrap');
  wrap.innerHTML='';
  for(var d=1;d<=days;d++){
    var slots='';
    for(var m=1;m<=S.cnt;m++){
      var prev=(old[d]&&old[d][m])||'';
      var opts='<option value="">— وجبة '+m+' —</option>';
      for(var k=0;k<meals.length;k++){opts+='<option value="'+meals[k]+'"'+(meals[k]===prev?' selected':'')+'>'+meals[k]+'</option>';}
      slots+='<select id="s'+d+'_'+m+'" onchange="onMeal('+d+','+m+',this.value)">'+opts+'</select>';
      slots+='<span class="mv-span" id="mv'+d+'_'+m+'"></span>';
      if(!S.plan[d])S.plan[d]={};
      S.plan[d][m]=prev;
    }
    wrap.innerHTML+='<div class="day-card" id="dc'+d+'"><div class="dc-head">يوم '+d+'</div><div class="dc-body">'+slots+'<div class="err-line" id="el'+d+'"></div></div></div>';
  }
  doStats(); doValidate();
}

function onMeal(d,m,v){if(!S.plan[d])S.plan[d]={};S.plan[d][m]=v;doStats();doValidate();}

function countMeals(){
  var c={},days=parseInt(S.per)||0;
  for(var d=1;d<=days;d++) for(var m=1;m<=S.cnt;m++){var v=(S.plan[d]&&S.plan[d][m])||'';if(v)c[v]=(c[v]||0)+1;}
  return c;
}

function doValidate(){
  var days=parseInt(S.per)||0, mr=maxRep(), counts=countMeals();
  for(var d=1;d<=days;d++){
    var card=document.getElementById('dc'+d);var el=document.getElementById('el'+d);var errTxt='';
    for(var m=1;m<=S.cnt;m++){
      var sel=document.getElementById('s'+d+'_'+m);if(!sel)continue;
      var v=(S.plan[d]&&S.plan[d][m])||'';sel.classList.remove('sw','se');
      if(v){if(counts[v]>mr){sel.classList.add('se');errTxt='"'+v+'" تكررت '+counts[v]+' مرات (الحد '+mr+')';}else if(counts[v]===mr)sel.classList.add('sw');}
    }
    if(errTxt){el.textContent='⚠️ '+errTxt;el.classList.add('show');card.classList.add('bad');}
    else{el.textContent='';el.classList.remove('show');card.classList.remove('bad');}
  }
}

function doStats(){
  var counts=countMeals(),mr=maxRep(),bar=document.getElementById('statsBar'),keys=Object.keys(counts);
  if(!keys.length){bar.innerHTML='<span style="color:#999;font-size:12px">ابدأ بالاختيار...</span>';return;}
  var html='';
  for(var i=0;i<keys.length;i++){var n=keys[i],c=counts[n];var cls=c<mr?'ok':c===mr?'warn':'err';var ico=c<mr?'✅':c===mr?'⚠️':'❌';html+='<span class="chip '+cls+'">'+ico+' '+n+': '+c+'/'+mr+'</span>';}
  bar.innerHTML=html;
}

