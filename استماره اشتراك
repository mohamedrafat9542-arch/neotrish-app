function setChk(id,on){
  const el=document.getElementById(id);
  if(!el) return;
  if(on){el.classList.add('on');el.textContent='✓';}
  else{el.classList.remove('on');el.textContent='';}
}
function clearGroup(prefix){
  document.querySelectorAll('[id^="'+prefix+'"]').forEach(function(el){el.classList.remove('on');el.textContent='';});
}

function pickSameDay(v){
  S.sameDay=v;
  setChk('sd-yes',v==='yes'); setChk('sd-no',v==='no'); setChk('sd-date',v==='date');
  var badge=document.getElementById('sdBadge');
  var vsd=document.getElementById('vSameDay');
  var txt='';
  if(v==='yes') txt='✅ نعم، يستلم في يوم الاشتراك (اليوم)';
  else if(v==='no') txt='❌ لا، يبدأ الاستلام من اليوم التالي';
  else if(v==='date'){var dateVal=document.getElementById('fDate').value; txt='📅 يستلم في تاريخ الاشتراك: '+(dateVal||'—');}
  badge.textContent=txt; vsd.textContent=txt;
}

function updateAddonVisibility(){
  var rowXchi=document.getElementById('row-xchi');
  var rowXmix=document.getElementById('row-xmix');
  if(S.pkg==='chi'){
    rowXchi.classList.remove('hidden'); rowXmix.classList.add('hidden');
    var i=S.adds.indexOf('xmix'); if(i>-1){S.adds.splice(i,1);setChk('ad-xmix',false);}
  } else if(S.pkg==='mix'){
    rowXmix.classList.remove('hidden'); rowXchi.classList.add('hidden');
    var j=S.adds.indexOf('xchi'); if(j>-1){S.adds.splice(j,1);setChk('ad-xchi',false);}
  } else {
    rowXchi.classList.remove('hidden'); rowXmix.classList.remove('hidden');
  }
}

function pickPkg(p){S.pkg=p;clearGroup('pk-');setChk('pk-'+p,true);updateAddonVisibility();calcPrice();refreshPlanner();refreshBranchPlanner();}
function pickCount(n){S.cnt=n;clearGroup('ct-');setChk('ct-'+n,true);calcPrice();refreshPlanner();refreshBranchPlanner();}
