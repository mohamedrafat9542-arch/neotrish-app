<!DOCTYPE html>

<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NEOTRISH</title>
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;900&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/signature_pad@4.1.7/dist/signature_pad.umd.min.js"></script>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Cairo',sans-serif;background:#ddd;padding:15px}
.page{background:#fff;max-width:900px;margin:auto;border:2px solid #111;font-family:'Cairo',sans-serif}

/* HEADER */
.hdr{display:flex;justify-content:space-between;align-items:center;padding:15px 20px;border-bottom:3px solid #111;background:#fff}
.logo{font-size:26px;font-weight:900;letter-spacing:2px;color:#111}
.logo span{color:#2e7d32}
.hdr-sub{font-weight:700;font-size:14px}

/* BODY */
.fb{padding:18px}

/* INFO FIELDS */
.info-grid{display:grid;grid-template-columns:1fr 1fr;border:2px solid #111;margin-bottom:14px}
.info-cell{padding:10px 12px;display:flex;align-items:center;gap:8px;border-left:2px solid #111}
.info-cell:last-child,.info-cell.full{border-left:none}
.info-cell.full{grid-column:span 2;border-top:2px solid #111;border-left:none}
.info-cell label{font-size:13px;font-weight:700;white-space:nowrap;color:#111}
.info-cell input{flex:1;border:none;border-bottom:1px solid #aaa;outline:none;font-family:‘Cairo’;font-size:13px;padding:2px 4px;color:#111}
.vspan{display:none;flex:1;font-size:13px;font-weight:700;color:#111;border-bottom:1px solid #ccc}

/* SUB TYPE — compact inline */
.subtype-bar{border:2px solid #111;margin-bottom:14px;overflow:hidden}
.subtype-bar-head{background:#111;color:#F5C800;padding:8px 14px;font-size:12px;font-weight:700;display:flex;align-items:center;gap:6px}
.subtype-bar-opts{display:flex;border-top:none}
.st-pill{flex:1;display:flex;align-items:center;justify-content:center;gap:7px;padding:10px 6px;cursor:pointer;user-select:none;border-left:2px solid #111;font-size:12px;font-weight:700;color:#555;background:#fff;transition:background .15s,color .15s;text-align:center;position:relative}
.st-pill:last-child{border-left:none}
.st-pill:hover{background:#fffbe6;color:#111}
.st-pill.active{background:#111;color:#F5C800}
.st-pill .st-pill-ico{font-size:16px;line-height:1}
.st-pill .st-pill-dot{position:absolute;top:6px;right:6px;width:8px;height:8px;border-radius:50%;border:2px solid #ccc;background:#fff}
.st-pill.active .st-pill-dot{background:#F5C800;border-color:#F5C800}
/* Delivery location row */
.loc-row{display:none;background:#f0f7ff;border-top:2px solid #3498db;padding:12px 14px;flex-direction:column;gap:8px}
.loc-row.show{display:flex}
.loc-step{font-size:12px;font-weight:700;color:#1a5276;margin-bottom:2px}
.loc-actions{display:flex;gap:8px;flex-wrap:wrap}
.loc-open-btn{display:flex;align-items:center;gap:6px;background:#3498db;color:#fff;border:none;border-radius:6px;padding:9px 14px;font-family:‘Cairo’;font-size:12px;font-weight:700;cursor:pointer;text-decoration:none;white-space:nowrap}
.loc-open-btn:active{background:#2980b9}
.loc-paste-wrap{display:flex;align-items:center;gap:6px;width:100%}
.loc-paste-input{flex:1;border:2px solid #3498db;border-radius:6px;padding:8px 10px;font-family:‘Cairo’;font-size:12px;color:#111;outline:none;background:#fff;min-width:0}
.loc-paste-input::placeholder{color:#aaa}
.loc-paste-input.filled{border-color:#2ecc71;background:#f0fff4}
.loc-paste-btn{background:#3498db;color:#fff;border:none;border-radius:6px;padding:8px 12px;font-family:‘Cairo’;font-size:11px;font-weight:700;cursor:pointer;white-space:nowrap;flex-shrink:0}
.loc-confirm{font-size:11px;color:#27ae60;font-weight:700;display:none}
.loc-confirm.show{display:block}
.loc-spinner{display:none;width:16px;height:16px;border:2px solid rgba(52,152,219,.3);border-top-color:#3498db;border-radius:50%;animation:spin .7s linear infinite;flex-shrink:0}
@keyframes spin{to{transform:rotate(360deg)}}
/* capture */
.vspan-st{display:none;font-size:12px;font-weight:700;color:#111;padding:6px 14px;background:#f5f5f5;border-top:1px solid #ddd}
body.cap .vspan-st{display:block!important}
body.cap .subtype-bar-opts{display:none!important}
body.cap .loc-row{display:none!important}

/* SAME-DAY PICKUP */
.sameday-cell{grid-column:span 2;border-top:2px solid #111;border-left:none;background:#fffbe6;padding:10px 14px;display:flex;align-items:center;gap:14px;flex-wrap:wrap}
.sameday-label{font-size:13px;font-weight:700;color:#7a5c00;white-space:nowrap}
.sameday-opts{display:flex;gap:18px;flex-wrap:wrap}
.sd-opt{display:flex;align-items:center;gap:7px;cursor:pointer;font-size:13px;font-weight:700;color:#111;user-select:none}
.sameday-badge{display:none;background:#2e7d32;color:#fff;font-size:11px;font-weight:700;padding:2px 10px;border-radius:20px;white-space:nowrap}
.vspan-sd{display:none;font-size:13px;font-weight:700;color:#7a5c00}

/* SELECTION GRID */
.sel-grid{display:grid;grid-template-columns:1fr 1fr 1fr 1.3fr;border:2px solid #111;margin-bottom:16px}
.sg-col{border-left:2px solid #111;padding:0}
.sg-col:last-child{border-left:none}
.sg-head{background:#111;color:#F5C800;text-align:center;padding:8px 5px;font-size:13px;font-weight:700}
.sg-body{padding:10px 8px}
.opt-row{display:flex;align-items:center;gap:8px;margin-bottom:10px;cursor:pointer;font-size:13px;font-weight:600;color:#111;user-select:none}
.opt-row:last-child{margin-bottom:0}
.chk{width:20px;height:20px;border:2px solid #111;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:900;flex-shrink:0;background:#fff;color:#F5C800}
.chk.on{background:#111}
.opt-row.hidden{display:none}

/* PRICE BAR */
.price-bar{background:#111;color:#F5C800;text-align:center;padding:14px;font-size:20px;font-weight:900;margin-bottom:16px}

/* MEAL CHOICE */
.mc-grid{display:grid;grid-template-columns:1fr 1fr;border:2px solid #111;margin-bottom:16px}
.mc-opt{display:flex;align-items:center;gap:10px;padding:14px 12px;cursor:pointer;font-size:14px;font-weight:700;color:#111;border-left:2px solid #111;user-select:none}
.mc-opt:last-child{border-left:none}

/* PLANNER */
.planner{display:none;border:2px solid #111;margin-bottom:18px}
.planner.show{display:block}
.pl-head{background:#111;color:#F5C800;padding:10px 14px;font-size:13px;font-weight:700;display:flex;flex-wrap:wrap;justify-content:space-between;gap:6px}
.pl-rule{background:rgba(255,255,255,.12);padding:3px 10px;border-radius:20px;font-size:12px}
.pl-stats{display:flex;flex-wrap:wrap;gap:6px;padding:10px 14px;background:#f7f7f7;border-bottom:1px solid #ddd;min-height:38px}
.chip{font-size:11px;padding:3px 10px;border-radius:20px;border:1px solid;font-weight:600}
.chip.ok{background:#d4edda;border-color:#28a745;color:#155724}
.chip.warn{background:#fff3cd;border-color:#f39c12;color:#856404}
.chip.err{background:#f8d7da;border-color:#e74c3c;color:#721c24}
.days-wrap{display:grid;grid-template-columns:repeat(auto-fill,minmax(170px,1fr));gap:10px;padding:14px}
.day-card{border:1px solid #bbb;border-radius:6px;overflow:hidden}
.day-card.bad{border-color:#e74c3c;box-shadow:0 0 0 2px rgba(231,76,60,.25)}
.dc-head{background:#eee;text-align:center;padding:6px;font-size:12px;font-weight:700;border-bottom:1px solid #ccc;color:#111}
.dc-body{padding:8px}
.dc-body select{width:100%;margin-bottom:5px;font-family:‘Cairo’;font-size:12px;padding:5px 4px;border:1px solid #bbb;border-radius:4px;color:#111;background:#fff;outline:none}
.dc-body select.sw{border-color:#f39c12;background:#fff8e1}
.dc-body select.se{border-color:#e74c3c;background:#ffeaea}
.mv-span{display:none;font-size:11px;font-weight:700;margin-bottom:4px;color:#111;border-bottom:1px solid #eee;padding-bottom:3px}
.err-line{color:#e74c3c;font-size:11px;display:none;margin-top:2px;line-height:1.4}
.err-line.show{display:block}

/* TERMS */
.terms{margin:16px 0;border-top:2px solid #111;padding-top:14px}
.t-title{font-weight:900;font-size:15px;margin-bottom:10px;color:#111}
.t-list{font-size:12px;line-height:1.7;list-style:none}
.t-list li{margin-bottom:6px;padding-right:16px;position:relative;color:#222}
.t-list li::before{content:”•”;position:absolute;right:0;font-weight:900}
.agree-row{display:flex;align-items:center;justify-content:center;gap:10px;margin:16px 0;cursor:pointer;font-weight:700;font-size:14px;color:#111;user-select:none}
.sig-box{display:flex;justify-content:space-between;align-items:flex-end;padding:14px;background:#fafafa;border:1px dashed #aaa}
.sig-lbl{font-size:13px;font-weight:700;color:#111}
.sig-clear{font-size:11px;color:#999;cursor:pointer;text-align:center;margin-top:4px}
canvas{border-bottom:2px solid #111;display:block;background:#fff;cursor:crosshair}

/* SUBMIT */
.btn-sub{background:#F5C800;color:#111;border:2px solid #111;font-size:17px;font-weight:900;padding:15px;cursor:pointer;width:100%;font-family:‘Cairo’;margin-top:12px;display:block}
.btn-sub:hover{background:#e0b600}

/* SUCCESS */
.success{display:none;padding:30px 20px;text-align:center}
.success-btns{display:flex;flex-direction:column;gap:12px;margin-top:16px}
.btn-dl{background:#2ecc71;color:#fff;border:2px solid #111;font-size:16px;font-weight:900;padding:13px 20px;cursor:pointer;font-family:‘Cairo’;width:100%}
.btn-inv{background:#F5C800;color:#111;border:2px solid #111;font-size:16px;font-weight:900;padding:13px 20px;cursor:pointer;font-family:‘Cairo’;width:100%}
.wa-link{display:block;margin-top:16px;color:#25d366;font-weight:700;font-size:16px;text-decoration:none}

/* BRANCH PLANNER */
.branch-planner{display:none;border:2px solid #111;margin-bottom:18px}
.branch-planner.show{display:block}
.bp-head{background:#111;color:#F5C800;padding:10px 14px;font-size:13px;font-weight:700;display:flex;align-items:center;gap:8px}
.bp-notice{background:#fffbe6;border-bottom:2px solid #F5C800;padding:10px 14px;font-size:12px;font-weight:600;color:#7a5c00;text-align:center}
.bp-days-wrap{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:10px;padding:14px}
.bp-day-card{border:1px solid #bbb;border-radius:6px;overflow:hidden}
.bp-dc-head{background:#F5C800;text-align:center;padding:6px;font-size:12px;font-weight:700;border-bottom:1px solid #ccc;color:#111}
.bp-dc-body{padding:8px}
.bp-meal-row{display:flex;align-items:center;gap:6px;margin-bottom:5px;font-size:12px;font-weight:600;color:#111}
.bp-meal-row:last-child{margin-bottom:0}
.bp-meal-num{width:20px;height:20px;border-radius:50%;background:#111;color:#F5C800;font-size:10px;font-weight:900;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.bp-meal-name{flex:1;font-size:12px}

/* ══════════════════════════════════════════
INVOICE STYLES
══════════════════════════════════════════ */
#invoicePage{display:none;max-width:900px;margin:20px auto;direction:rtl;font-family:‘Cairo’,sans-serif}

.inv-wrap{background:#fff;border:3px solid #111;overflow:hidden}

/* Invoice Header */
.inv-header{background:#111;padding:0;display:flex;align-items:stretch;min-height:110px}
.inv-logo-side{background:#F5C800;padding:20px 28px;display:flex;flex-direction:column;align-items:center;justify-content:center;min-width:160px}
.inv-logo-text{font-size:28px;font-weight:900;letter-spacing:3px;color:#111;line-height:1}
.inv-logo-leaf{font-size:18px;margin-bottom:4px}
.inv-logo-sub{font-size:9px;font-weight:700;color:#111;letter-spacing:1px;margin-top:4px;opacity:.7}
.inv-title-side{flex:1;padding:20px 28px;display:flex;flex-direction:column;justify-content:center;align-items:flex-end}
.inv-title-ar{font-size:26px;font-weight:900;color:#F5C800;letter-spacing:1px}
.inv-title-en{font-size:11px;color:rgba(245,200,0,.6);letter-spacing:3px;text-transform:uppercase;margin-top:4px}
.inv-num-badge{background:rgba(245,200,0,.15);border:1px solid rgba(245,200,0,.3);border-radius:6px;padding:6px 14px;margin-top:10px;color:#F5C800;font-size:12px;font-weight:700}

/* Yellow stripe */
.inv-stripe{background:#F5C800;height:6px}

/* Info section */
.inv-info-row{display:grid;grid-template-columns:1fr 1fr;gap:0;border-bottom:2px solid #111}
.inv-info-block{padding:16px 20px}
.inv-info-block:first-child{border-left:2px solid #111}
.inv-info-title{font-size:10px;font-weight:700;color:#888;letter-spacing:2px;text-transform:uppercase;margin-bottom:10px;border-bottom:1px solid #eee;padding-bottom:6px}
.inv-info-row-item{display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;font-size:12px}
.inv-info-label{color:#666;font-weight:600}
.inv-info-val{font-weight:700;color:#111}

/* Items table */
.inv-table-wrap{padding:0}
.inv-table{width:100%;border-collapse:collapse;font-size:13px}
.inv-table th{background:#111;color:#F5C800;padding:10px 16px;font-weight:700;font-size:12px;text-align:right}
.inv-table td{padding:11px 16px;border-bottom:1px solid #eee;color:#111;font-weight:600}
.inv-table tr:last-child td{border-bottom:none}
.inv-table tr:nth-child(even) td{background:#fafafa}
.inv-table .item-num{background:#F5C800;color:#111;width:28px;height:28px;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;font-size:11px;font-weight:900}
.inv-qty{text-align:center}
.inv-price{text-align:left;color:#2e7d32;font-weight:900}

/* Total bar */
.inv-total-section{background:#111;padding:0;display:flex;justify-content:flex-end;align-items:stretch}
.inv-total-inner{display:flex;align-items:center;gap:30px;padding:16px 28px}
.inv-subtotal-col{text-align:left}
.inv-subtotal-label{font-size:11px;color:rgba(255,255,255,.6);font-weight:600}
.inv-subtotal-val{font-size:16px;font-weight:900;color:#fff}
.inv-total-divider{width:2px;height:50px;background:rgba(245,200,0,.4)}
.inv-total-col{text-align:left}
.inv-total-label{font-size:12px;color:#F5C800;font-weight:700;letter-spacing:1px}
.inv-total-val{font-size:32px;font-weight:900;color:#F5C800;line-height:1}
.inv-total-currency{font-size:14px;color:rgba(245,200,0,.7);margin-top:2px}

/* Payment section */
.inv-payment{background:#fffbe6;border-top:3px solid #F5C800;padding:16px 22px;display:flex;align-items:center;gap:20px;flex-wrap:wrap}
.inv-pay-icon{font-size:28px}
.inv-pay-info{flex:1}
.inv-pay-title{font-size:12px;font-weight:900;color:#7a5c00;margin-bottom:6px}
.inv-pay-detail{font-size:11px;color:#7a5c00;font-weight:600;line-height:1.8}
.inv-pay-iban{font-family:monospace;font-size:13px;font-weight:900;color:#111;background:#fff;border:1px solid #ddd;padding:4px 10px;border-radius:4px;display:inline-block;margin-top:4px;letter-spacing:1px}
.inv-pay-note{font-size:11px;color:#e74c3c;font-weight:700;margin-top:6px}

/* Footer */
.inv-footer{background:#f5f5f5;border-top:2px solid #111;padding:12px 22px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px}
.inv-footer-brand{font-size:13px;font-weight:900;color:#111}
.inv-footer-brand span{color:#2e7d32}
.inv-footer-contact{font-size:11px;color:#666;font-weight:600}
.inv-footer-stamp{background:#2e7d32;color:#fff;font-size:10px;font-weight:700;padding:4px 14px;border-radius:20px;letter-spacing:1px}

/* Watermark */
.inv-watermark{text-align:center;padding:10px;opacity:.08;font-size:60px;font-weight:900;color:#111;letter-spacing:8px;pointer-events:none;user-select:none;line-height:1}

/* Invoice action btns */
.inv-actions{display:flex;gap:10px;margin:14px 0;flex-wrap:wrap}
.inv-btn{flex:1;padding:13px;border:2px solid #111;font-family:‘Cairo’;font-size:15px;font-weight:900;cursor:pointer;min-width:140px}
.inv-btn-dl{background:#F5C800;color:#111}
.inv-btn-back{background:#fff;color:#111}
.inv-btn-wa{background:#25d366;color:#fff;border-color:#25d366}

/* PRINT / CAPTURE HIDE */
.cap-hide{display:block}
body.cap .cap-hide{display:none!important}
body.cap input,body.cap select,body.cap .btn-sub,body.cap .pl-stats,body.cap .err-line,body.cap .pl-rule{display:none!important}
body.cap .vspan,body.cap .mv-span,body.cap .vspan-sd,body.cap .vspan-st{display:block!important}
body.cap .sameday-badge{display:inline-block!important}
body.cap .sameday-opts{display:none!important}
body.cap .subtype-grid{display:none!important}
body.cap .gym-branch-opts{display:none!important}

@media(max-width:680px){
.sel-grid{grid-template-columns:1fr 1fr}
.info-grid{grid-template-columns:1fr}
.info-cell.full{grid-column:span 1;border-top:2px solid #111}
.sameday-cell{grid-column:span 1}
.info-cell{border-left:none;border-bottom:1px solid #ccc}
.inv-header{flex-direction:column}
.inv-logo-side{min-width:unset;width:100%}
.inv-info-row{grid-template-columns:1fr}
.inv-info-block:first-child{border-left:none;border-bottom:2px solid #111}
.inv-total-inner{flex-wrap:wrap;gap:14px}
.inv-table th,.inv-table td{padding:8px 10px;font-size:11px}
}
</style>

</head>
<body>

<div class="page" id="mainPage">

  <div class="hdr">
    <div class="logo">NEOTR<span>🌿</span>SH</div>
    <div class="hdr-sub">استمارة طلب اشتراك</div>
  </div>

  <div class="fb" id="formBody">

<div class="info-grid">
  <div class="info-cell">
    <label>الاسم:</label>
    <input type="text" id="fName" placeholder="الاسم الثلاثي">
    <span class="vspan" id="vName"></span>
  </div>
  <div class="info-cell">
    <label>الجوال:</label>
    <input type="tel" id="fPhone" placeholder="05xxxxxxxx">
    <span class="vspan" id="vPhone"></span>
  </div>
  <div class="info-cell full">
    <label>تاريخ بداية الاشتراك:</label>
    <input type="date" id="fDate">
    <span class="vspan" id="vDate"></span>
  </div>
  <div class="info-cell sameday-cell cap-hide">
    <span class="sameday-label">🍱 استلام وجبة في نفس يوم الاشتراك (اليوم الأول):</span>
    <div class="sameday-opts">
      <div class="sd-opt" onclick="pickSameDay('yes')"><div class="chk" id="sd-yes"></div>نعم، أستلم اليوم</div>
      <div class="sd-opt" onclick="pickSameDay('no')"><div class="chk" id="sd-no"></div>لا، من الغد</div>
      <div class="sd-opt" onclick="pickSameDay('date')"><div class="chk" id="sd-date"></div>أستلم في تاريخ الاشتراك</div>
    </div>
  </div>
  <div class="info-cell sameday-cell" style="display:none" id="sdCapRow">
    <span class="sameday-label">🍱 استلام اليوم الأول:</span>
    <span class="sameday-badge" id="sdBadge"></span>
    <span class="vspan-sd" id="vSameDay"></span>
  </div>
</div>

<div class="subtype-bar">
  <div class="subtype-bar-head">📍 نوع الاشتراك</div>
  <div class="subtype-bar-opts cap-hide">
    <div class="st-pill" id="st-restaurant" onclick="pickSubType('restaurant')">
      <div class="st-pill-dot"></div>
      <span class="st-pill-ico">🏪</span> استلام المطعم
    </div>
    <div class="st-pill" id="st-delivery" onclick="pickSubType('delivery')">
      <div class="st-pill-dot"></div>
      <span class="st-pill-ico">🚗</span> توصيل
    </div>
    <div class="st-pill" id="st-gym" onclick="pickSubType('gym')">
      <div class="st-pill-dot"></div>
      <span class="st-pill-ico">💪</span> جولدز جيم
    </div>
  </div>
  <div class="loc-row cap-hide" id="locRow">
    <div class="loc-step">📍 الخطوة 1: افتح الخرائط وشارك موقعك</div>
    <div class="loc-actions">
      <a class="loc-open-btn" id="locOpenBtn" href="https://maps.google.com" target="_blank" onclick="openMapsFlow()">
        🗺️ افتح خرائط جوجل
      </a>
      <div class="loc-spinner" id="locSpinner"></div>
    </div>
    <div class="loc-step" id="locStep2" style="display:none">📋 الخطوة 2: انسخ رابط موقعك والصقه هنا</div>
