function getLocation(){}

function openMapsFlow(){
  var step2=document.getElementById('locStep2');
  var pasteWrap=document.getElementById('locPasteWrap');
  var spinner=document.getElementById('locSpinner');
  var openBtn=document.getElementById('locOpenBtn');

  spinner.style.display='block';

  if(navigator.geolocation){
    navigator.geolocation.getCurrentPosition(function(pos){
      spinner.style.display='none';
      userLat=pos.coords.latitude.toFixed(6);
      userLng=pos.coords.longitude.toFixed(6);
      var url='https://maps.google.com/?q='+userLat+','+userLng;
      userLocText=url;
      var inp=document.getElementById('locInput');
      inp.value=url;
      inp.classList.add('filled');
      step2.style.display='block';
      pasteWrap.style.display='flex';
      document.getElementById('locConfirm').classList.add('show');
      openBtn.textContent='✅ تم تحديد الموقع تلقائياً';
      openBtn.style.background='#27ae60';
      updateSubTypeLabel();
    }, function(){
      spinner.style.display='none';
      step2.style.display='block';
      pasteWrap.style.display='flex';
      openBtn.innerHTML='🗺️ افتح الخرائط مجدداً';
    },{enableHighAccuracy:true,timeout:8000});
  } else {
    spinner.style.display='none';
    step2.style.display='block';
    pasteWrap.style.display='flex';
  }
}

function onLocInput(val){
  val=val.trim();
  var confirm=document.getElementById('locConfirm');
  var inp=document.getElementById('locInput');
  if(val.length>10 && (val.includes('maps') || val.includes('goo.gl') || val.includes('loc') || /\d+\.\d+/.test(val))){
    userLocText=val;
    userLat='set'; userLng='set';
    inp.classList.add('filled');
    confirm.classList.add('show');
    updateSubTypeLabel();
  } else {
    userLocText=''; userLat=null; userLng=null;
    inp.classList.remove('filled');
    confirm.classList.remove('show');
    updateSubTypeLabel();
  }
}

async function pasteFromClipboard(){
  try{
    var text=await navigator.clipboard.readText();
    var inp=document.getElementById('locInput');
    inp.value=text;
    onLocInput(text);
  } catch(e){
